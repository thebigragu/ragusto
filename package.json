{
  "name": "arcform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "models:laptop": "blender --background --python blender/build_hero_laptop.py",
    "models:chair": "blender --background --python blender/build_hero_chair.py",
    "models:lounge": "blender --background --python blender/build_lounge.py",
    "models:hero": "blender --background --python blender/build_studio_hero.py",
    "models:pavilion": "blender --background --python blender/build_pavilion.py",
    "models": "npm run models:laptop",
    "videos:hero": "blender --background --python blender/render_hero_desk_loop.py",
    "videos:process": "blender --background --python blender/render_process_atrium_loop.py",
    "videos:encode": "node scripts/encode-videos.cjs",
    "videos": "npm run videos:encode"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "gsap": "^3.15.0",
    "lenis": "^1.3.25",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.185.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
